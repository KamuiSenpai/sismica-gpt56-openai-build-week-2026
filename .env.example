DATABASE_URL=postgres://postgres:postgres@localhost:5433/sismica
SISMICA_PGDATA=.runtime/pgsql-data-mvp
SISMICA_PGPORT=5433
API_PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
# Activa solo detras de un reverse proxy que normalice X-Forwarded-For.
API_TRUST_PROXY=false
# Protege diagnosticos y operaciones administrativas. Debe tener 24+ caracteres.
API_OPERATOR_TOKEN=
# Cuotas por IP para endpoints que consumen OpenAI, TTS o CPU/GPU.
API_RATE_LIMIT_WINDOW_MS=60000
API_AI_RATE_LIMIT_MAX=10
API_COMPUTE_RATE_LIMIT_MAX=120
# La API sirve el ultimo resumen materializado y lo renueva en segundo plano.
ANALYTICS_REFRESH_INTERVAL_MS=3600000
ANALYTICS_REFRESH_BATCH_SIZE=50000
STREAM_CHANNEL=seismic_events_channel
STATION_STREAM_CHANNEL=seismic_station_states_channel
# Token compartido entre la API (adaptador interno) y el motor experimental (worker).
# Debe tener 24+ caracteres. Genera uno con: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SEISMIC_ENGINE_TOKEN=
# Motor experimental (worker): triangulacion por busqueda en malla sobre eventos reales.
SEISMIC_ENGINE_ENABLED=true
SEISMIC_ENGINE_API_URL=http://localhost:3000
SEISMIC_ENGINE_INTERVAL_MS=120000
SEISMIC_ENGINE_MAX_STATIONS=8
SEISMIC_ENGINE_MAX_EVENTS=6
USGS_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson
CWA_AUTHORIZATION=
CWA_EARTHQUAKE_URL=https://opendata.cwa.gov.tw/api/v1/rest/datastore/E-A0016-002?format=JSON&limit=100
EMSC_FDSN_URL=https://www.seismicportal.eu/fdsnws/event/1/query
GEOFON_FDSN_URL=https://geofon.gfz.de/fdsnws/event/1/query
GEOFON_FDSN_STATION_URL=https://geofon.gfz.de/fdsnws/station/1/query
GEONET_QUAKE_URL=https://api.geonet.org.nz/quake?MMI=-1
BMKG_LATEST_URL=https://data.bmkg.go.id/DataMKG/TEWS/gempaterkini.json
BMKG_FELT_URL=https://data.bmkg.go.id/DataMKG/TEWS/gempadirasakan.json
JMA_LIST_URL=https://www.jma.go.jp/bosai/quake/data/list.json
INGV_FDSN_URL=https://webservices.ingv.it/fdsnws/event/1/query
SGC_FIVE_DAYS_ALL_URL=https://archive.sgc.gov.co/feed/v1.0.1/summary/five_days_all.json
IGN_EARTHQUAKES_JS_URL=https://www.ign.es/web/resources/sismologia/tproximos/terremotos.js
SSN_RSS_URL=http://www.ssn.unam.mx/rss/ultimos-sismos.xml
CSN_HOME_URL=https://www.sismologia.cl/
IGP_FEED_URL_TEMPLATE=https://ultimosismo.igp.gob.pe/api/ultimo-sismo/ajaxb/{year}
FUNVISIS_FEED_URL=http://www.funvisis.gob.ve/maravilla.json
GDACS_API_URL=https://www.gdacs.org/gdacsapi/api/events/geteventlist/SEARCH
NOAA_PTWC_CAP_URL=https://www.tsunami.gov/events/xml/PHEBCAP.xml
NOAA_NTWC_CAP_URL=https://www.tsunami.gov/events/xml/PAAQCAP.xml
# --- TTS neural local (API) ---
# Activa los endpoints /api/tts y /api/tts/health. Con false, el front usa la voz del navegador.
TTS_ENABLED=false
XTTS_ENABLED=false
# Piper: binario y modelo de voz en español (ver README). Ejemplo con assets bajo models/piper/.
PIPER_BINARY_PATH=models/piper/piper.exe
PIPER_VOICE_MODEL=models/piper/es_MX-claude-high.onnx
PIPER_USE_CUDA=false
# XTTS-v2: URL del microservicio Python (services/tts-xtts). Vacío = motor XTTS deshabilitado.
XTTS_SERVICE_URL=http://127.0.0.1:8090
# Cache en disco de audios sintetizados (opcional pero recomendado).
TTS_CACHE_DIR=.tts-cache
TTS_MAX_TEXT_LENGTH=600
# Chatterbox: recomendado para RTX 4060 Ti 8 GB con rotacion de 6 voces.
CHATTERBOX_SERVICE_URL=http://127.0.0.1:8091
CHATTERBOX_DEVICE=cuda
CHATTERBOX_PRECISION=bf16
CHATTERBOX_CACHE_CONDITIONING=true
CHATTERBOX_CONDITIONING_CACHE_LIMIT=6
CHATTERBOX_PROFILE_WARMUP=all
CHATTERBOX_COMPILE_MODE=off
CHATTERBOX_REPETITION_PENALTY=2.2
# --- Narracion por IA (DeepSeek) ---
# Con DEEPSEEK_ENABLED=false (o sin API key) la voz usa la plantilla local.
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=120
DEEPSEEK_RATE_PER_MIN=30
# --- Build Week: explicador sismico con OpenAI GPT-5.6 ---
# Activa solo para la demo. La clave permanece en .env y nunca se versiona.
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_MS=15000
# --- Bot de chat de YouTube ---
# off: desactivado
# dry-run: registra y drena cola, pero no publica en YouTube
# live: publica realmente en el chat del directo activo
YOUTUBE_CHAT_ENABLED=false
YOUTUBE_CHAT_MODE=off
YOUTUBE_CHAT_CLIENT_ID=
YOUTUBE_CHAT_CLIENT_SECRET=
YOUTUBE_CHAT_REFRESH_TOKEN=
YOUTUBE_CHAT_CHANNEL_ID=
YOUTUBE_CHAT_MIN_INTERVAL_MS=12000
YOUTUBE_CHAT_MAX_EVENT_AGE_MINUTES=20
YOUTUBE_CHAT_MAX_QUEUE_SIZE=200
YOUTUBE_CHAT_STALE_QUEUE_MS=180000
YOUTUBE_CHAT_PROMOTIONAL_ENABLED=true
YOUTUBE_CHAT_PROMOTIONAL_MIN_INTERVAL_MS=1200000
YOUTUBE_CHAT_PUBLISH_INTERVAL_MS=3000
POLL_INTERVAL_MS=60000
SOURCE_TIMEOUT_MS=20000
SOURCE_WINDOW_HOURS=72
STATION_CATALOG_REFRESH_MS=86400000
RUN_ONCE=false
VITE_API_BASE_URL=http://localhost:3000
# trial usa las pautas actuales; cambiar a official solo despues de aprobar los WAV de produccion.
VITE_DIRECTOR_V2_GUIDE_SET=trial
