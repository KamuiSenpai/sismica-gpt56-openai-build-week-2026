# Copia este archivo a .env y completa los valores.

# Token de Cesium Ion (gratis en https://ion.cesium.com/tokens).
# Si se deja vacio, el globo usa imagery satelital de ESRI (sin token) como fallback.
VITE_CESIUM_ION_TOKEN=

# Base URL del backend propio (API REST + SSE).
VITE_API_BASE_URL=http://localhost:3000
